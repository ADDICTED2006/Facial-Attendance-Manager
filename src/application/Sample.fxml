<BorderPane prefHeight="720.0" prefWidth="1350.0" style="-fx-background-color: #f0f4f8;" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="application.SampleController">
   <center>
      <TitledPane alignment="CENTER" collapsible="false" prefHeight="530.0" prefWidth="712.0" text="Teacher Kiosk / Attendance Scanner" BorderPane.alignment="CENTER" style="-fx-font-weight: bold; -fx-font-size: 16px;">
        <content>
          <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="485.0" prefWidth="749.0" style="-fx-background-color: #ffffff;">
               <children>
                  <ImageView fx:id="frame" fitHeight="417.0" fitWidth="727.0" layoutY="5.0" pickOnBounds="true" preserveRatio="true" AnchorPane.rightAnchor="90.0">
                     <viewport>
                        <Rectangle2D width="700.0" />
                     </viewport></ImageView>
                  <Button fx:id="startCam" layoutX="10.0" layoutY="440.0" mnemonicParsing="false" onAction="#startCamera" prefHeight="40.0" prefWidth="100.0" text="Start Cam" style="-fx-background-color: #1a73e8; -fx-text-fill: white; -fx-background-radius: 6; -fx-font-weight: bold; -fx-cursor: hand;" />
                  <Button fx:id="stopBtn" layoutX="10.0" layoutY="440.0" mnemonicParsing="false" onAction="#stopCam" prefHeight="40.0" prefWidth="100.0" text="Stop Cam" visible="false" style="-fx-background-color: #d93025; -fx-text-fill: white; -fx-background-radius: 6; -fx-font-weight: bold; -fx-cursor: hand;" />
                  
                  <Button fx:id="saveBtn" disable="true" layoutX="120.0" layoutY="440.0" mnemonicParsing="false" onAction="#saveFace" prefHeight="40.0" prefWidth="100.0" text="Save Face" style="-fx-background-color: #34a853; -fx-text-fill: white; -fx-background-radius: 6; -fx-font-weight: bold; -fx-cursor: hand;" />
                  
                  <Button fx:id="motionBtn" disable="true" layoutX="230.0" layoutY="440.0" mnemonicParsing="false" onAction="#startMotion" prefHeight="40.0" prefWidth="100.0" text="Motion" style="-fx-background-color: #fbbc05; -fx-text-fill: white; -fx-background-radius: 6; -fx-font-weight: bold; -fx-cursor: hand;" />
                  
                  <Button fx:id="recogniseBtn" disable="true" layoutX="340.0" layoutY="440.0" mnemonicParsing="false" onAction="#faceRecognise" prefHeight="40.0" prefWidth="140.0" text="Start Scanner" style="-fx-background-color: #1a73e8; -fx-text-fill: white; -fx-background-radius: 6; -fx-font-weight: bold; -fx-cursor: hand;" />
                  <Button fx:id="stopRecBtn" disable="true" layoutX="490.0" layoutY="440.0" mnemonicParsing="false" onAction="#stopRecognise" prefHeight="40.0" prefWidth="140.0" text="Stop Scanner" style="-fx-background-color: #d93025; -fx-text-fill: white; -fx-background-radius: 6; -fx-font-weight: bold; -fx-cursor: hand;" />
                  
                  <Button fx:id="capBtn" alignment="CENTER" disable="true" layoutX="640.0" layoutY="440.0" mnemonicParsing="false" prefHeight="40.0" prefWidth="100.0" text="Capture" style="-fx-background-color: #5f6368; -fx-text-fill: white; -fx-background-radius: 6; -fx-font-weight: bold; -fx-cursor: hand;" />
                  
                  <Separator layoutX="10.0" layoutY="425.0" prefWidth="730.0" />
                  
                  <Label fx:id="savedLabel" layoutX="282.0" layoutY="207.0" prefHeight="52.0" prefWidth="215.0" text="Face Saved!" visible="false" textFill="#34a853">
                     <font>
                        <Font name="System Bold" size="28.0" />
                     </font>
                  </Label>
                  <ProgressIndicator fx:id="pb" layoutX="360.0" layoutY="156.0" progress="0.0" visible="false" />
                  <Label fx:id="warning" layoutX="100.0" layoutY="365.0" prefHeight="40.0" prefWidth="550.0" style="-fx-background-color: #fce8e6; -fx-background-radius: 6; -fx-border-color: #d93025; -fx-border-radius: 6; -fx-padding: 5;" text=" Warning: Name or Reg or Code Field Cannot Be empty!" textFill="#d93025" visible="false" alignment="CENTER">
                     <font>
                        <Font name="System Bold" size="14.0" />
                     </font>
                  </Label>
               </children>
            </AnchorPane>
        </content>
      </TitledPane>
   </center>
   <left>
      <TitledPane fx:id="dataPane" disable="true" prefHeight="528.0" prefWidth="302.0" text="Student Registration" BorderPane.alignment="CENTER" style="-fx-font-weight: bold; -fx-font-size: 14px;">
         <content>
            <SplitPane dividerPositions="0.5" orientation="VERTICAL" prefHeight="276.0" prefWidth="300.0" style="-fx-background-color: #ffffff;">
              <items>
                <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="100.0" prefWidth="160.0">
                     <children>
                        <ListView fx:id="output" editable="true" layoutX="4.0" layoutY="4.0" prefHeight="242.0" prefWidth="290.0" style="-fx-padding: 5; -fx-background-color: white; -fx-border-color: #dadce0;" />
                     </children>
                </AnchorPane>
                <AnchorPane fx:id="pdPane" minHeight="0.0" minWidth="0.0" prefHeight="100.0" prefWidth="160.0">
                     <children>
                        <Label fx:id="title" layoutX="31.0" layoutY="5.0" text="Person Data" textFill="#1a73e8">
                           <font>
                              <Font name="System Bold" size="18.0" />
                           </font>
                        </Label>
                        <Label layoutX="29.0" layoutY="70.0" text="FName:" textFill="#5f6368">
                           <font><Font name="System Bold" size="12.0" /></font>
                        </Label>
                        <TextField fx:id="fname" layoutX="90.0" layoutY="66.0" prefHeight="25.0" prefWidth="180.0" promptText="Enter First Name" style="-fx-background-color: #f8f9fa; -fx-border-color: #dadce0; -fx-border-radius: 4;" />
                        
                        <Label layoutX="29.0" layoutY="40.0" text="Code:" textFill="#5f6368">
                           <font><Font name="System Bold" size="12.0" /></font>
                        </Label>
                        <TextField fx:id="code" layoutX="90.0" layoutY="36.0" prefHeight="25.0" prefWidth="180.0" promptText="Unique Face Code" style="-fx-background-color: #f8f9fa; -fx-border-color: #dadce0; -fx-border-radius: 4;" />
                        
                        <Label layoutX="29.0" layoutY="100.0" text="LName:" textFill="#5f6368">
                           <font><Font name="System Bold" size="12.0" /></font>
                        </Label>
                        <TextField fx:id="lname" layoutX="90.0" layoutY="96.0" prefHeight="25.0" prefWidth="180.0" promptText="Enter Last Name" style="-fx-background-color: #f8f9fa; -fx-border-color: #dadce0; -fx-border-radius: 4;" />
                        
                        <Label layoutX="29.0" layoutY="130.0" text="Reg No:" textFill="#5f6368">
                           <font><Font name="System Bold" size="12.0" /></font>
                        </Label>
                        <TextField fx:id="reg" layoutX="90.0" layoutY="126.0" prefHeight="25.0" prefWidth="180.0" promptText="Registration No." style="-fx-background-color: #f8f9fa; -fx-border-color: #dadce0; -fx-border-radius: 4;" />
                        
                        <Label layoutX="29.0" layoutY="160.0" text="Age:" textFill="#5f6368">
                           <font><Font name="System Bold" size="12.0" /></font>
                        </Label>
                        <TextField fx:id="age" layoutX="90.0" layoutY="156.0" prefHeight="25.0" prefWidth="180.0" promptText="Age" style="-fx-background-color: #f8f9fa; -fx-border-color: #dadce0; -fx-border-radius: 4;" />
                        
                        <Label layoutX="29.0" layoutY="190.0" text="Section:" textFill="#5f6368">
                           <font><Font name="System Bold" size="12.0" /></font>
                        </Label>
                        <TextField fx:id="sec" layoutX="90.0" layoutY="186.0" prefHeight="25.0" prefWidth="180.0" promptText="Section" style="-fx-background-color: #f8f9fa; -fx-border-color: #dadce0; -fx-border-radius: 4;" />
                        
                        <Separator layoutX="30.0" layoutY="32.0" prefWidth="240.0" />
                        <ImageView fx:id="motionView" fitHeight="211.0" fitWidth="298.0" layoutX="2.0" layoutY="32.0" pickOnBounds="true" preserveRatio="true" visible="false" />
                     </children>
                  </AnchorPane>
              </items>
            </SplitPane>
         </content>
      </TitledPane>
   </left>
   <right>
      <TitledPane animated="false" prefHeight="524.0" prefWidth="266.0" text="Activity Logs" BorderPane.alignment="CENTER" style="-fx-font-weight: bold; -fx-font-size: 14px;">
        <content>
          <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="498.0" prefWidth="338.0" style="-fx-background-color: white;">
               <children>
                  <SplitPane layoutX="2.0" layoutY="-1.0" orientation="VERTICAL" prefHeight="496.0" prefWidth="280.0" style="-fx-background-color: white;">
                     <items>
                        <ScrollPane prefHeight="494.0" prefViewportHeight="244.0" prefViewportWidth="328.0" prefWidth="260.0" style="-fx-background-color: white; -fx-border-color: white;">
                           <content>
                            <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="496.0" prefWidth="260.0" style="-fx-background-color: white;">
                                 <children>
                                    <Label layoutX="10.0" layoutY="10.0" text="EVENT LOG:" textFill="#1a73e8">
                                       <font>
                                          <Font name="System Bold" size="14.0" />
                                       </font>
                                    </Label>
                                    <Separator layoutX="10.0" layoutY="30.0" prefWidth="240.0" />
                                    <ListView fx:id="logList" editable="true" layoutX="10.0" layoutY="35.0" prefHeight="200.0" prefWidth="240.0" style="-fx-background-color: #f8f9fa; -fx-border-color: #dadce0; -fx-border-radius: 4;" />
                                    
                                    <Label layoutX="10.0" layoutY="245.0" text="OCR OUTPUT:" textFill="#1a73e8">
                                       <font>
                                          <Font name="System Bold" size="14.0" />
                                       </font>
                                    </Label>
                                    <Separator layoutX="10.0" layoutY="265.0" prefWidth="240.0" />
                                    <ScrollPane layoutX="10.0" layoutY="270.0" prefHeight="200.0" prefWidth="240.0" style="-fx-background-color: #f8f9fa; -fx-border-color: #dadce0; -fx-border-radius: 4;">
                                      <content>
                                        <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="196.0" prefWidth="236.0" style="-fx-background-color: #f8f9fa;">
                                             <children>
                                                <TextFlow fx:id="ocr" focusTraversable="true" layoutX="5.0" layoutY="5.0" prefHeight="186.0" prefWidth="226.0" />
                                             </children>
                                          </AnchorPane>
                                      </content>
                                    </ScrollPane>
                                 </children>
                              </AnchorPane>
                           </content>
                        </ScrollPane>
                     </items>
                  </SplitPane>
               </children>
          </AnchorPane>
        </content>
      </TitledPane>
   </right>
   <bottom>
      <Pane prefHeight="195.0" prefWidth="1354.0" BorderPane.alignment="CENTER" style="-fx-background-color: #f0f4f8;">
         <children>
            <TitledPane animated="false" prefHeight="206.0" prefWidth="1350.0" text="Face Database" style="-fx-font-weight: bold; -fx-font-size: 14px;">
              <content>
                  <ScrollPane prefViewportHeight="180.0" prefViewportWidth="1348.0" style="-fx-background-color: white;">
                     <content>
                        <TilePane fx:id="tile" hgap="30.0" prefHeight="181.0" prefWidth="1438.0" vgap="30.0" style="-fx-background-color: white;">
                           <padding>
                              <Insets bottom="50.0" top="10.0" left="10.0" />
                           </padding>
                        </TilePane>
                     </content>
                  </ScrollPane>
              </content>
            </TitledPane>
         </children>
      </Pane>
   </bottom>
</BorderPane>
